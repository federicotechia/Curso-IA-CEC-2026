rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {uid}
    // Fields:
    //   - email: string (required)
    //   - role: string (required, 'profesor' | 'alumno')
    //   - status: string (required, 'pending' | 'approved')
    //   - displayName: string (optional)
    //   - uid: string (required)
    //
    // Collection: modules
    // Document ID: {moduleId}
    // Fields:
    //   - title: string (required)
    //   - description: string (optional)
    //   - visible: bool (required)
    //   - order: number (required)
    //   - materials: list (optional)
    //   - extra: list (optional)
    //   - task: map (optional)
    //
    // Collection: forum
    // Document ID: {postId}
    // Fields:
    //   - user: string (required)
    //   - text: string (required)
    //   - date: string (required)
    //   - uid: string (required)
    //
    // Collection: submissions
    // Document ID: {submissionId}
    // Fields:
    //   - studentName: string (required)
    //   - studentUid: string (required)
    //   - taskId: number (required)
    //   - fileName: string (required)
    //   - date: string (required)
    //   - status: string (required, 'Recibido' | 'Calificado')
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isSuperAdmin() {
      return isAuthenticated() && 
             (request.auth.token.email == "federicotechia@gmail.com" || 
              request.auth.token.email == "fede.trillini@gmail.com");
    }

    function isAdmin() {
      return isSuperAdmin() || (
        isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['profesor', 'administrador'])
      );
    }

    function isApproved() {
      return isSuperAdmin() || (
        isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.status == 'approved' || 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['profesor', 'administrador'])
      );
    }

    function isValidUser(data, userId) {
      return data.keys().hasAll(['email', 'role', 'status', 'uid']) &&
             data.email is string && data.email.size() < 200 &&
             data.role in ['profesor', 'alumno', 'administrador'] &&
             data.status in ['pending', 'approved'] &&
             data.uid == userId &&
             (!('displayName' in data) || (data.displayName is string && data.displayName.size() < 200)) &&
             (!('survey_completed' in data) || data.survey_completed is bool) &&
             (!('suggested_level' in data) || data.suggested_level in ['Principiante', 'Avanzado']);
    }

    function isValidSurveyResponse(data) {
      return data.keys().hasAll(['user_id', 'user_name', 'familiarity', 'tools', 'frequency', 'professional_profile', 'automation_goal', 'technical_validation', 'timestamp', 'suggested_level']) &&
             data.user_id == request.auth.uid &&
             data.familiarity is number && data.familiarity >= 1 && data.familiarity <= 5 &&
             data.tools is list &&
             data.frequency is string &&
             data.suggested_level in ['Principiante', 'Avanzado'] &&
             (!('custom_responses' in data) || data.custom_responses is map);
    }

    function isValidModule(data) {
      return data.keys().hasAll(['title', 'visible', 'order']) &&
             data.title is string && data.title.size() < 200 &&
             (!('description' in data) || (data.description is string && data.description.size() < 5000)) &&
             data.visible is bool &&
             data.order is number;
    }

    function isValidPost(data) {
      return data.keys().hasAll(['user', 'text', 'date', 'uid']) &&
             data.user is string && data.user.size() < 100 &&
             data.text is string && data.text.size() < 5000 &&
             data.uid is string;
    }

    function isValidSubmission(data) {
      return data.keys().hasAll(['studentName', 'studentUid', 'taskId', 'taskTitle', 'fileName', 'fileUrl', 'date', 'status']) &&
             data.studentName is string && data.studentName.size() < 200 &&
             data.studentUid is string &&
             data.taskTitle is string && data.taskTitle.size() < 200 &&
             data.fileName is string && data.fileName.size() < 500 &&
             data.fileUrl is string && data.fileUrl.size() < 2000 &&
             data.status in ['Recibido', 'Calificado'];
    }

    function isValidTask(data) {
      return data.keys().hasAll(['id', 'title', 'description', 'deadline', 'order']) &&
             data.id is string &&
             data.title is string && data.title.size() < 200 &&
             data.description is string && data.description.size() < 5000 &&
             data.deadline is string &&
             data.order is number;
    }

    function isValidSurveyConfig(data) {
      return data.keys().hasAll(['toolsOptions', 'advancedTools', 'frequencyOptions', 'technicalOptions', 'advancedThresholdFrequency', 'advancedThresholdTechnical']) &&
             data.toolsOptions is list &&
             data.advancedTools is list &&
             data.frequencyOptions is list &&
             data.technicalOptions is list &&
             (!('customQuestions' in data) || data.customQuestions is list);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isValidUser(request.resource.data, userId) && (
        (isOwner(userId) && request.resource.data.role == 'alumno' && request.resource.data.status == 'pending') ||
        isAdmin()
      );
      allow update: if isAuthenticated() && isValidUser(request.resource.data, userId) && (
        (isOwner(userId) && request.resource.data.role == resource.data.role && request.resource.data.status == resource.data.status) ||
        isAdmin()
      );
      allow delete: if isAdmin();
    }
    
    match /config/survey {
      allow read: if isAuthenticated();
      allow write: if isAdmin() && isValidSurveyConfig(request.resource.data);
    }

    match /modules/{moduleId} {
      allow read: if isApproved() && (resource.data.visible == true || isAdmin());
      allow write: if isAdmin() && isValidModule(request.resource.data);
    }

    match /forum/{postId} {
      allow read: if isApproved();
      allow create: if isApproved() && isValidPost(request.resource.data) && request.resource.data.uid == request.auth.uid;
      allow update: if isAdmin() || (isApproved() && resource.data.uid == request.auth.uid && isValidPost(request.resource.data));
      allow delete: if isAdmin() || (isApproved() && resource.data.uid == request.auth.uid);
      
      match /replies/{replyId} {
        allow read: if isApproved();
        allow create: if isApproved() && isValidPost(request.resource.data) && request.resource.data.uid == request.auth.uid;
        allow update: if isAdmin() || (isApproved() && resource.data.uid == request.auth.uid && isValidPost(request.resource.data));
        allow delete: if isAdmin() || (isApproved() && resource.data.uid == request.auth.uid);
      }
    }

    match /tasks/{taskId} {
      allow read: if isApproved();
      allow write: if isAdmin() && isValidTask(request.resource.data);
    }

    match /submissions/{submissionId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.studentUid == request.auth.uid);
      allow create: if isApproved() && isValidSubmission(request.resource.data) && request.resource.data.studentUid == request.auth.uid && request.resource.data.status == 'Recibido';
      allow update: if isAdmin() && isValidSubmission(request.resource.data);
      allow delete: if isAdmin();
    }

    match /survey_responses/{responseId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated() && isValidSurveyResponse(request.resource.data);
    }

    // Default deny
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
